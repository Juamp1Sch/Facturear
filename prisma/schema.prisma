generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String?        @map("password_hash")
  emailVerifiedAt              DateTime? @map("email_verified_at")
  verificationTokenHash        String?   @map("verification_token_hash")
  verificationTokenExpiresAt   DateTime? @map("verification_token_expires_at")
  passwordResetTokenHash       String?   @map("password_reset_token_hash")
  passwordResetTokenExpiresAt  DateTime? @map("password_reset_token_expires_at")
  invoices      Invoice[]
  suppliers     Supplier[]
  chartAccounts         ChartAccount[]
  supplierChartAccounts SupplierChartAccountLink[]
  taxChartAccountSettings TaxChartAccountSettings?
  taxChartAccountPerceptionLinks TaxChartAccountPerceptionLink[]
  storedFiles           StoredFile[]
  integrationConfig     IntegrationConfig?
  cuitEmpresas           CuitEmpresa[]
  cuitSucursales         CuitSucursal[]
  createdAt             DateTime                   @default(now()) @map("created_at")
}

/// Facturas guardadas en Postgres cuando S3 no está configurado (p. ej. Vercel + Neon).
model StoredFile {
  key         String   @id
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentType String   @map("content_type")
  data        Bytes
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("stored_files")
}

model Invoice {
  id                  String             @id @default(cuid())
  userId              String             @map("user_id")
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  batchId             String?            @map("batch_id")
  originalFileUrl     String             @map("original_file_url")
  originalFileKey     String             @map("original_file_key")
  mimeType            String             @map("mime_type")
  rawOcrText          String?            @map("raw_ocr_text") @db.Text
  providerName        String?            @map("provider_name")
  providerCuit        String?            @map("provider_cuit")
  supplierCode        String?            @map("supplier_code")
  invoiceNumber       String?            @map("invoice_number")
  invoiceType         String?            @map("invoice_type")
  invoiceDate         DateTime?          @map("invoice_date")
  netAmount           Decimal?           @map("net_amount") @db.Decimal(14, 2)
  vatAmount           Decimal?           @map("vat_amount") @db.Decimal(14, 2)
  perceptionsAmount   Decimal?           @map("perceptions_amount") @db.Decimal(14, 2)
  totalAmount         Decimal?           @map("total_amount") @db.Decimal(14, 2)
  accountingAccountId String?            @map("accounting_account_id")
  accountingAccount   AccountingAccount? @relation(fields: [accountingAccountId], references: [id])
  chartAccountId      String?            @map("chart_account_id")
  chartAccount        ChartAccount?      @relation(fields: [chartAccountId], references: [id])
  movementId          String?            @unique @map("movement_id")
  empresa             String?            @map("empresa")
  sucursal            String?            @map("sucursal")
  documentKind        String?            @map("document_kind")
  status              InvoiceStatus      @default(PROCESSING)
  aiConfidence        Float?             @map("ai_confidence")
  aiPayload           Json?              @map("ai_payload")
  destinationUploadedAt   DateTime? @map("destination_uploaded_at")
  destinationUploadStatus Int?      @map("destination_upload_status")
  destinationUploadBody   String?   @map("destination_upload_body") @db.Text
  createdAt           DateTime           @default(now()) @map("created_at")
  corrections         Correction[]
  files               InvoiceFile[]

  @@index([batchId])
}

model InvoiceFile {
  id          String   @id @default(cuid())
  invoiceId   String   @map("invoice_id")
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  partIndex   Int      @map("part_index")
  fileKey     String   @map("file_key")
  fileUrl     String   @map("file_url")
  mimeType    String   @map("mime_type")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([invoiceId, partIndex])
  @@map("invoice_files")
}

model AccountingAccount {
  id       String    @id @default(cuid())
  code     String    @unique
  name     String
  type     String
  invoices Invoice[]
}

model Correction {
  id             String   @id @default(cuid())
  invoiceId      String   @map("invoice_id")
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  field          String
  previousValue  String?  @map("previous_value") @db.Text
  correctedValue String   @map("corrected_value") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
}

enum InvoiceStatus {
  PROCESSING
  READY
  ERROR
  CORRECTED
}

model Supplier {
  id                 String                     @id @default(cuid())
  userId             String                     @map("user_id")
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  code               String
  cuit               String?
  name               String
  address            String?                    @db.Text
  locality           String?                    @map("locality")
  chartAccountLink   SupplierChartAccountLink?
  createdAt          DateTime                   @default(now()) @map("created_at")
  updatedAt          DateTime                   @updatedAt @map("updated_at")

  @@unique([userId, code])
  @@map("suppliers")
}

model ChartAccount {
  id            String                     @id @default(cuid())
  userId        String                     @map("user_id")
  user          User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  code          String
  name          String
  type          String?                    @map("account_type")
  active        Boolean                    @default(true)
  invoices      Invoice[]
  supplierLinks SupplierChartAccountLink[]
  vatTaxSettings                TaxChartAccountSettings[]           @relation("VatChartAccount")
  taxChartAccountPerceptionLinks TaxChartAccountPerceptionLink[]
  createdAt     DateTime                   @default(now()) @map("created_at")
  updatedAt     DateTime                   @updatedAt @map("updated_at")

  @@unique([userId, code])
  @@map("chart_accounts")
}

model TaxChartAccountSettings {
  id                String        @id @default(cuid())
  userId            String        @unique @map("user_id")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vatChartAccountId String?       @map("vat_chart_account_id")
  vatChartAccount   ChartAccount? @relation("VatChartAccount", fields: [vatChartAccountId], references: [id], onDelete: SetNull)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@map("tax_chart_account_settings")
}

model TaxChartAccountPerceptionLink {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  chartAccountId String       @map("chart_account_id")
  chartAccount   ChartAccount @relation(fields: [chartAccountId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([userId, chartAccountId])
  @@map("tax_chart_account_perception_links")
}

model SupplierChartAccountLink {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  supplierId     String       @unique @map("supplier_id")
  supplier       Supplier     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  chartAccountId String       @map("chart_account_id")
  chartAccount   ChartAccount @relation(fields: [chartAccountId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([userId, supplierId])
  @@map("supplier_chart_account_links")
}

model IntegrationConfig {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String   @default("EXTERNAL")
  apiUrl    String   @map("api_url")
  userToken String   @map("user_token") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("integration_configs")
}

model CuitEmpresa {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cuit      String
  value     String
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, cuit, value])
  @@index([userId, cuit])
  @@map("cuit_empresas")
}

model CuitSucursal {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cuit      String
  value     String
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, cuit, value])
  @@index([userId, cuit])
  @@map("cuit_sucursales")
}
