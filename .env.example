# PostgreSQL (e.g. Neon). Required for the app.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/facturear?schema=public"

# Used for local file URLs when not using S3 (no trailing slash).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth.js / NextAuth v5 — must be a long random string (signs the session JWT).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Set as AUTH_SECRET=... below. (Do not use plain `npx auth secret` — npm may install
# Better Auth and suggest BETTER_AUTH_SECRET; this app also reads BETTER_AUTH_SECRET if present.)
AUTH_SECRET=
AUTH_TRUST_HOST=true

# SMTP (registro con activación manual por código)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="AgileScan <noreply@agilescan.com.ar>"
REGISTRATION_NOTIFY_EMAIL=info@agilescan.com.ar

# --- AWS S3 (opcional en local). En Vercel: las 4 variables O solo DATABASE_URL (archivos en Neon) ---
# Nombres exactos; bucket solo el nombre (ej. mi-bucket), sin s3://
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
# Alias aceptado en Vercel si ya creaste S3_BUCKET_NAME:
# S3_BUCKET_NAME=

# OpenAI
OPENAI_API_KEY=
# gpt-4o recomendado para lectura precisa de importes en fotos; gpt-4o-mini es más barato pero menos preciso con dígitos.
OPENAI_MODEL=gpt-4o
