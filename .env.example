# PostgreSQL (e.g. Neon). Required for the app.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/facturear?schema=public"

# Used for local file URLs when not using S3 (no trailing slash).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Seeded demo user (see prisma/seed.ts).
DEFAULT_USER_EMAIL="demo@facturear.local"

# --- AWS S3 (optional). If any of these are missing, files are stored under .data/uploads/ ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
